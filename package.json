{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/meridian.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/meridian.js",
      "types": "./dist/types/index.d.ts"
    },
    "./tokens.css": "./dist/meridian.css"
  },
  "scripts": {
    "dev:site": "vite --config site/vite.config.ts",
    "dev:demo": "vite --config demo/vite.config.ts",
    "build": "tsc -b && vite build && tsc -p tsconfig.build.json",
    "build:site": "vite build --config site/vite.config.ts",
    "build:demo": "vite build --config demo/vite.config.ts",
    "preview:site": "vite preview --config site/vite.config.ts",
    "preview:demo": "vite preview --config demo/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "ag-grid-community": "^33.0.0",
    "ag-grid-react": "^33.0.0",
    "flexlayout-react": "^0.8.19",
    "plotly.js-finance-dist-min": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-plotly.js": "^2.6.0"
  },
  "devDependencies": {
    "lucide-react": "^1.7.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-plotly.js": "^2.6.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
